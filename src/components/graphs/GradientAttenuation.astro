---
import PlotlyGraph from "../PlotlyGraph.astro";

const d2Values = [2, 4, 8, 16, 32];
const attenuationValues = [0.74, 20.44, 0.47, 0.43, 0.70];
const mseGap = [-0.78, -0.94, 0.31, 0.61, -0.45];

const data = [
  {
    x: d2Values,
    y: attenuationValues,
    mode: "lines+markers",
    name: "𝔼[eᵗ] (Gradient Scale)",
    line: { color: "#1d4ed8", width: 3 },
    marker: { size: 12 },
    yaxis: "y",
  },
  {
    x: d2Values,
    y: mseGap,
    mode: "lines+markers",
    name: "MSE Gap (Euc - Hyp)",
    line: { color: "#059669", width: 3, dash: "dot" },
    marker: { size: 10, symbol: "square" },
    yaxis: "y2",
  },
];

const layout = {
  title: "Gradient Attenuation & Performance Gap",
  xaxis: {
    title: "Latent Dimension (d₂)",
    type: "log",
    tickvals: d2Values,
    ticktext: d2Values.map(String),
  },
  yaxis: {
    title: "𝔼[eᵗ] (log scale)",
    type: "log",
    color: "#1d4ed8",
  },
  yaxis2: {
    title: "MSE Gap (positive = hyperbolic wins)",
    overlaying: "y",
    side: "right",
    color: "#059669",
    zeroline: true,
    zerolinecolor: "#666",
    zerolinewidth: 2,
  },
  hovermode: "x unified",
  legend: {
    x: 0.02,
    y: 0.98,
  },
  annotations: [
    {
      x: 4,
      y: Math.log10(20.44),
      text: "Instability spike",
      showarrow: true,
      arrowhead: 2,
      ax: 40,
      ay: -40,
      font: { size: 12 },
    },
  ],
};
---

<PlotlyGraph id="gradient-attenuation" data={data} layout={layout} />
