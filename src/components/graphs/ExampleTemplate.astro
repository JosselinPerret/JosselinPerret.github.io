---
// TEMPLATE: Copy this file to create new interactive graphs
// 1. Copy this file to src/components/graphs/YourGraphName.astro
// 2. Update the data arrays with your values
// 3. Customize layout (title, axis labels, colors)
// 4. Import in your .mdx article

import PlotlyGraph from "../PlotlyGraph.astro";

// Example: Simple line plot
const data = [
  {
    x: [1, 2, 3, 4, 5],
    y: [2, 4, 3, 5, 6],
    mode: "lines+markers",
    name: "Dataset 1",
    line: { color: "#1d4ed8", width: 3 },
    marker: { size: 8 },
  },
  {
    x: [1, 2, 3, 4, 5],
    y: [1, 3, 2, 4, 5],
    mode: "lines+markers",
    name: "Dataset 2",
    line: { color: "#dc2626", width: 3, dash: "dash" },
    marker: { size: 8 },
  },
];

const layout = {
  title: "Your Graph Title",
  xaxis: {
    title: "X Axis Label",
  },
  yaxis: {
    title: "Y Axis Label",
  },
  hovermode: "x unified",
  legend: {
    x: 0.7,
    y: 0.95,
  },
};

// Optional: custom config
const config = {
  responsive: true,
  displayModeBar: true,
};
---

<PlotlyGraph id="example-graph" data={data} layout={layout} config={config} />
