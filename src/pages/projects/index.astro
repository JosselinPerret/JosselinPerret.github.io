---
import { getCollection } from "astro:content";
import { siteConfig } from "../../config";
import "../../styles/global.css";

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={`All projects by ${siteConfig.name}`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <title>Projects | {siteConfig.name}</title>
  </head>
  <body class="bg-white text-gray-900">
    <main class="mx-auto max-w-6xl p-8 sm:p-12 md:p-16 lg:p-24">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <a href="/" class="text-sm text-gray-500 hover:text-gray-900">← Back to home</a>
          <h1 class="mt-3 text-4xl sm:text-5xl font-bold">All Projects</h1>
          <p class="mt-2 text-gray-600">A full list of project pages, sorted by most recent first.</p>
        </div>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2">
        {
          projects.map((project) => (
            <a
              href={`/projects/${project.slug}`}
              class="group rounded-2xl border border-gray-200 bg-gray-50 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-gray-300 hover:bg-white hover:shadow-lg"
            >
              <div class="mb-5 overflow-hidden rounded-lg border border-gray-200 bg-white">
                <img
                  src={project.data.coverImage ?? "/images/projects/placeholder-cover.svg"}
                  alt={project.data.coverImageAlt ?? `${project.data.title} cover image`}
                  class="h-44 w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                  loading="lazy"
                />
              </div>

              <p class="text-xs text-gray-500">
                {project.data.publishedAt.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </p>
              <h2 class="mt-2 text-2xl font-bold text-gray-900">{project.data.title}</h2>
              <p class="mt-3 text-gray-600">{project.data.description}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {project.data.skills.map((skill) => (
                  <span class="rounded-lg bg-gray-900 px-2.5 py-1 text-xs text-white">{skill}</span>
                ))}
              </div>
              <p class="mt-6 text-sm font-semibold text-gray-900 group-hover:text-gray-700">
                Open project page →
              </p>
            </a>
          ))
        }
      </div>
    </main>
  </body>
</html>
