---
import { siteConfig } from "../../config";
import "../../styles/global.css";

type Project = (typeof siteConfig.projects)[number];

export function getStaticPaths() {
  return siteConfig.projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props as { project: Project };
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={project.description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <title>{project.name} | {siteConfig.name}</title>
  </head>
  <body class="bg-white text-gray-900">
    <main class="mx-auto max-w-4xl p-8 sm:p-12 md:p-16 lg:p-24">
      <div class="mb-8 flex flex-wrap items-center gap-4 text-sm">
        <a href="/" class="text-gray-500 hover:text-gray-900">← Home</a>
        <a href="/projects" class="text-gray-500 hover:text-gray-900">All projects</a>
      </div>

      <header>
        <p class="text-xs text-gray-500">
          {new Date(project.publishedAt).toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </p>
        <h1 class="mt-3 text-4xl sm:text-5xl font-bold">{project.name}</h1>
        <p class="mt-4 text-lg text-gray-600">{project.description}</p>
        <div class="mt-6 flex flex-wrap gap-2">
          {project.skills.map((skill) => (
            <span class="rounded-lg bg-gray-900 px-2.5 py-1 text-xs text-white">{skill}</span>
          ))}
        </div>
      </header>

      <section class="mt-12 space-y-10">
        <article>
          <h2 class="text-2xl font-bold">Project overview</h2>
          <p class="mt-3 text-gray-700">
            [Placeholder] Write a short introduction to this project: problem, goals, and key outcome.
          </p>
        </article>

        <article>
          <h2 class="text-2xl font-bold">Story and approach</h2>
          <p class="mt-3 text-gray-700">
            [Placeholder] Describe your process, architecture choices, trade-offs, and what you learned.
          </p>
        </article>

        <article>
          <h2 class="text-2xl font-bold">Images and media</h2>
          <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div class="flex h-48 items-center justify-center rounded-xl border-2 border-dashed border-gray-300 bg-gray-50 text-sm text-gray-500">
              [Placeholder image 1]
            </div>
            <div class="flex h-48 items-center justify-center rounded-xl border-2 border-dashed border-gray-300 bg-gray-50 text-sm text-gray-500">
              [Placeholder image 2]
            </div>
          </div>
          <p class="mt-3 text-sm text-gray-500">
            Add your images later from the public folder and replace these placeholders.
          </p>
        </article>

        <article>
          <h2 class="text-2xl font-bold">Next steps</h2>
          <p class="mt-3 text-gray-700">
            [Placeholder] Mention future improvements, backlog ideas, or experiments.
          </p>
        </article>
      </section>

      {
        project.repoUrl && (
          <div class="mt-12">
            <a
              href={project.repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center rounded-lg bg-gray-900 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-gray-700"
            >
              Repository link
            </a>
          </div>
        )
      }
    </main>
  </body>
</html>
